# CyberPot .env configuration template
# This file is generated by Ansible during CyberPot installation

# Web usernames and passwords (base64 encoded htpasswd format)
WEB_USER={{ lookup('file', '/tmp/web_user.txt') }}

# Logstash Web usernames and passwords (base64 encoded htpasswd format)
LS_WEB_USER={{ lookup('file', '/tmp/ls_web_user.txt') }}

# CyberPot Blackhole
# ENABLED: Download known mass scanners database and nullroute them
# DISABLED: No stealth efforts (default)
CYBERPOT_BLACKHOLE=DISABLED

# CyberPot Persistence
# on: Keep honeypot logfiles and rotate with logrotate for 30 days (default)
# off: Recommended for setups with limited storage or weaker CPUs
CYBERPOT_PERSISTENCE=on

# CyberPot Type
# HIVE: Standard installation with all services (default)
# SENSOR: Sensor-only installation for distributed deployment
# MOBILE: Mobile-optimized configuration
CYBERPOT_TYPE={{ cyberpot_type | default('HIVE') }}

# CyberPot AttackMap Text Output
# ENABLED: Print events to console (default)
# DISABLED: Disable console output
CYBERPOT_ATTACKMAP_TEXT=ENABLED

# CyberPot AttackMap Text Output Timezone
# UTC: Universal Time (default, recommended)
# Continent/City: Local timezone (e.g., America/New_York, Europe/London)
CYBERPOT_ATTACKMAP_TEXT_TIMEZONE=UTC

# Docker Configuration
# Repository for CyberPot Docker images
CYBERPOT_REPO=ghcr.io/khulnasoft

# CyberPot version to deploy
CYBERPOT_VERSION={{ cyberpot_version }}

# Pull policy for Docker images
# always: Always pull latest images (default)
# missing: Only pull if not cached locally
# never: Never pull, use only cached images
CYBERPOT_PULL_POLICY=always

# Base data directory for CyberPot
CYBERPOT_DATA_PATH=./data

# Operating System Type
# linux: Standard Linux deployment (default)
# mac: macOS deployment (limited features)
# win: Windows deployment (limited features)
CYBERPOT_OSTYPE=linux

# Environment identifier (for monitoring and organization)
CYBERPOT_ENVIRONMENT={{ cyberpot_environment }}

# Deployment timestamp
CYBERPOT_DEPLOYED={{ ansible_date_time.iso8601 }}

# Additional configuration for distributed deployments
# Uncomment and configure for SENSOR deployments

# CyberPot Hive User (for SENSOR deployments)
# Base64 encoded "username:password" for Hive authentication
# CYBERPOT_HIVE_USER=

# Logstash SSL verification (for SENSOR deployments)
# full: Verify complete certificate chain (default)
# none: Disable SSL verification (not recommended for production)
# LS_SSL_VERIFICATION=full

# CyberPot Hive IP (for SENSOR deployments)
# IP address or FQDN of the Hive server
# CYBERPOT_HIVE_IP=
